<Window x:Class="FashionPOS.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OPERATOR CONFIGURATION" 
        Height="520" MinHeight="520" Width="400"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        Background="{StaticResource DarkBgBrush}">
    <Border Padding="32" Background="{StaticResource CardBgBrush}" CornerRadius="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Bottom" Background="Transparent" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="CANCEL" Click="Cancel_Click" Style="{StaticResource GhostButton}" Width="140" Margin="0,0,10,0" />
                    <Button x:Name="SaveButton" Content="SAVE CONFIG" Click="Save_Click" Style="{StaticResource GoldPrimaryButton}" Width="140" />
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Background="{StaticResource CyberBlueBrush}" Height="5" CornerRadius="2" Margin="0,0,0,20" />
                    <TextBlock x:Name="DialogHeaderText" Text="OPERATOR CONFIG" Style="{StaticResource SectionTitle}" FontSize="20" Margin="0,0,0,8" Foreground="White" />
                    <TextBlock Text="IDENTITY // PERMISSIONS // STATUS" 
                               Style="{StaticResource SectionSubtitle}" 
                               Foreground="{StaticResource CyberBlueBrush}" 
                               FontWeight="Bold" 
                               Margin="0,0,0,32"/>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="FULL NAME" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="FullNameBox" Style="{StaticResource ModernTextBox}" />
                    </StackPanel>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="USERNAME" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="UsernameBox" Style="{StaticResource ModernTextBox}" />
                    </StackPanel>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="ACCESS KEY" Style="{StaticResource InputLabel}"/>
                        <PasswordBox x:Name="PasswordInput" Style="{StaticResource ModernPasswordBox}" />
                        <TextBlock Text="[SYSTEM NOTICE: LEAVE EMPTY TO MAINTAIN CURRENT KEY]" 
                                   FontSize="9" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   FontWeight="Bold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="ROLE ASSIGNMENT" Style="{StaticResource InputLabel}"/>
                            <ComboBox x:Name="RoleBox" Style="{StaticResource ModernComboBox}" Height="44" Padding="10,8" HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Bottom">
                            <CheckBox x:Name="IsActiveCheck" 
                                      Content="OPERATOR ACTIVE" 
                                      Foreground="White" 
                                      FontSize="11"
                                      FontWeight="Bold"
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
