<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FashionPOS.Views.ProductEditDialog"
        Title="Edit Product"
        Height="600" Width="520"
        MinHeight="600" MinWidth="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#131B2E">
    <DockPanel>

        <!-- Top accent bar -->
        <Rectangle DockPanel.Dock="Top" Height="4" Fill="#00AAFF"/>

        <!-- BOTTOM buttons always visible — docked before content -->
        <Border DockPanel.Dock="Bottom"
                Background="#0D1526"
                BorderBrush="#1E3050" BorderThickness="0,1,0,0"
                Padding="24,16">
            <Grid>
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        HorizontalAlignment="Left"
                        Width="110" Height="42"
                        Background="Transparent"
                        Foreground="#888888"
                        BorderBrush="#2A3A50" BorderThickness="1"
                        FontSize="13" Cursor="Hand"
                        Click="CancelButton_Click"/>
                <Button x:Name="SaveButton"
                        Content="Save product"
                        HorizontalAlignment="Right"
                        Width="150" Height="42"
                        Background="#C9A84C"
                        Foreground="#0F0F0F"
                        FontWeight="Bold" FontSize="13"
                        BorderThickness="0" Cursor="Hand"
                        Click="SaveButton_Click"/>
            </Grid>
        </Border>

        <!-- SCROLLABLE FORM CONTENT -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0">
            <StackPanel Margin="28,24,28,16">

                <!-- Header -->
                <TextBlock Text="Product details"
                           FontSize="20" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,4"/>
                <TextBlock Text="Add or update a clothing item"
                           FontSize="12" Foreground="#607090"
                           Margin="0,0,0,24"/>

                <!-- Name -->
                <TextBlock Text="NAME" FontSize="10" Foreground="#607090"
                           FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBox x:Name="NameBox"
                         Height="42" Padding="12,10"
                         Background="#0D1526" Foreground="White"
                         BorderBrush="#1E3050" BorderThickness="1"
                         FontSize="13" CaretBrush="#C9A84C"
                         Margin="0,0,0,16"/>

                <!-- SKU -->
                <TextBlock Text="SKU" FontSize="10" Foreground="#607090"
                           FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBox x:Name="SkuBox"
                         Height="42" Padding="12,10"
                         Background="#0D1526" Foreground="White"
                         BorderBrush="#1E3050" BorderThickness="1"
                         FontSize="13" CaretBrush="#C9A84C"
                         Margin="0,0,0,16"/>

                <!-- Collection + Category row -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="COLLECTION" FontSize="10" Foreground="#607090"
                                   FontWeight="Bold" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CollectionBox"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name"
                                  Height="44" Padding="12,10"
                                  FontSize="13"
                                  Background="#0D1526"
                                  Foreground="White"
                                  BorderBrush="#1E3050" BorderThickness="1"
                                  Margin="0,0,0,0">
                            <ComboBox.Resources>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="#0D1526"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </ComboBox.Resources>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="CATEGORY" FontSize="10" Foreground="#607090"
                                   FontWeight="Bold" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CategoryBox"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name"
                                  Height="44" Padding="12,10"
                                  FontSize="13"
                                  Background="#0D1526"
                                  Foreground="White"
                                  BorderBrush="#1E3050" BorderThickness="1"
                                  Margin="0,0,0,0">
                            <ComboBox.Resources>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="#0D1526"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </ComboBox.Resources>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Size + Color row -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SIZE" FontSize="10" Foreground="#607090"
                                   FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox x:Name="SizeBox"
                                 Height="42" Padding="12,10"
                                 Background="#0D1526" Foreground="White"
                                 BorderBrush="#1E3050" BorderThickness="1"
                                 FontSize="13" CaretBrush="#C9A84C"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="COLOR" FontSize="10" Foreground="#607090"
                                   FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox x:Name="ColorBox"
                                 Height="42" Padding="12,10"
                                 Background="#0D1526" Foreground="White"
                                 BorderBrush="#1E3050" BorderThickness="1"
                                 FontSize="13" CaretBrush="#C9A84C"/>
                    </StackPanel>
                </Grid>

                <!-- Cost + Selling price row -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="COST PRICE" FontSize="10" Foreground="#607090"
                                   FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox x:Name="CostPriceBox"
                                 Height="42" Padding="12,10"
                                 Background="#0D1526" Foreground="White"
                                 BorderBrush="#1E3050" BorderThickness="1"
                                 FontSize="13" CaretBrush="#C9A84C"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SELLING PRICE" FontSize="10" Foreground="#607090"
                                   FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox x:Name="SellingPriceBox"
                                 Height="42" Padding="12,10"
                                 Background="#0D1526" Foreground="White"
                                 BorderBrush="#1E3050" BorderThickness="1"
                                 FontSize="13" CaretBrush="#C9A84C"/>
                    </StackPanel>
                </Grid>

                <!-- Stock + Low stock threshold row -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="STOCK QUANTITY" FontSize="10" Foreground="#607090"
                                   FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox x:Name="StockBox"
                                 Height="42" Padding="12,10"
                                 Background="#0D1526" Foreground="White"
                                 BorderBrush="#1E3050" BorderThickness="1"
                                 FontSize="13" CaretBrush="#C9A84C"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="LOW STOCK ALERT" FontSize="10" Foreground="#607090"
                                   FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox x:Name="ThresholdBox"
                                 Height="42" Padding="12,10"
                                 Background="#0D1526" Foreground="White"
                                 BorderBrush="#1E3050" BorderThickness="1"
                                 FontSize="13" CaretBrush="#C9A84C"/>
                    </StackPanel>
                </Grid>

                <!-- Barcode -->
                <TextBlock Text="BARCODE" FontSize="10" Foreground="#607090"
                           FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBox x:Name="BarcodeBox"
                         Height="42" Padding="12,10"
                         Background="#0D1526" Foreground="White"
                         BorderBrush="#1E3050" BorderThickness="1"
                         FontSize="13" CaretBrush="#C9A84C"
                         Margin="0,0,0,8"/>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
