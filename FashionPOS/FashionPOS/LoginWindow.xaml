<Window x:Class="FashionPOS.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GERBERA // CONTROL PANEL ACCESS"
        Height="620"
        Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="{StaticResource DarkBgBrush}">
    <Grid>
        <!-- Background Glow -->
        <Border Background="{StaticResource DarkBgBrush}" />

        <Border Margin="32" 
                Background="{StaticResource SidebarBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="32">
            <StackPanel VerticalAlignment="Center">
                <!-- Branding -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Border Background="{StaticResource CyberCyanBrush}" Width="4" Height="36" CornerRadius="2" Margin="0,0,12,0"/>
                    <TextBlock Text="GERBERA" 
                               Foreground="White" 
                               FontSize="32" 
                               FontWeight="Black"/>
                </StackPanel>
                <TextBlock Text="BOUTIQUE // MANAGEMENT SYSTEM" 
                           Foreground="{StaticResource CyberCyanBrush}" 
                           FontSize="10" 
                           FontWeight="Black" 
                           HorizontalAlignment="Center"
                           Opacity="0.8"
                           Margin="0,0,0,48"/>

                <!-- Login Form -->
                <StackPanel>
                    <TextBlock Text="AUTHORIZATION REQUIRED" 
                               Style="{StaticResource SectionSubtitle}" 
                               HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Margin="0,0,0,24"/>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="OPERATOR ID" Style="{StaticResource InputLabel}" />
                        <TextBox x:Name="UsernameBox"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="50" />
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="ACCESS KEY" Style="{StaticResource InputLabel}" />
                        <PasswordBox x:Name="PasswordInput"
                                     Background="#111827"
                                     Foreground="White"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     Padding="12,14"
                                     Height="50">
                            <PasswordBox.Template>
                                <ControlTemplate TargetType="PasswordBox">
                                    <Grid>
                                        <Border x:Name="BaseBorder" Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" Padding="{TemplateBinding Padding}" />
                                        </Border>
                                        <Border x:Name="FocusGlow" CornerRadius="10" BorderBrush="{StaticResource CyberCyanBrush}" BorderThickness="1" Opacity="0">
                                            <Border.Effect>
                                                <DropShadowEffect Color="{StaticResource CyberCyan}" BlurRadius="10" ShadowDepth="0" Opacity="0.4" />
                                            </Border.Effect>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter TargetName="FocusGlow" Property="Opacity" Value="1" />
                                            <Setter TargetName="BaseBorder" Property="BorderBrush" Value="{StaticResource CyberCyanBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </PasswordBox.Template>
                        </PasswordBox>
                    </StackPanel>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="11"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"
                               Margin="0,12,0,12" />

                    <Button x:Name="SignInButton"
                            Content="INITIALIZE SESSION"
                            Style="{StaticResource PrimaryButton}"
                            Height="56"
                            Margin="0,12,0,0"
                            Click="SignInButton_Click"
                            IsDefault="True"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />
                </StackPanel>

                <TextBlock Text="CREDENTIALS: gerbera / 123"
                           FontSize="9"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,32,0,0"
                           Opacity="0.5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
