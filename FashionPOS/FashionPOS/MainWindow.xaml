<Window x:Class="FashionPOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FashionPOS"
        xmlns:vm="clr-namespace:FashionPOS.ViewModels"
        xmlns:conv="clr-namespace:FashionPOS.Converters"
        Title="Gerbera Fashion POS" 
        Width="1280" 
        Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DarkBgBrush}">
    <Window.Resources>
        <!-- Cyber Background Pattern -->
        <DrawingBrush x:Key="DotPatternBrush" TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#1E293B">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,40,40" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#334155">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="2,2" RadiusX="0.5" RadiusY="0.5" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <Grid>
        <Grid Background="{StaticResource DotPatternBrush}" Opacity="0.4" />
        
        <DockPanel LastChildFill="True">
            <!-- Sidebar -->
            <Border Width="260" 
                    Background="{StaticResource SidebarBgBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Brand Section -->
                    <Border DockPanel.Dock="Top" Padding="32,48,32,24">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{StaticResource CyberCyanBrush}" Width="4" Height="32" CornerRadius="2" Margin="0,0,12,0"/>
                                <TextBlock Text="GERBERA" 
                                         Foreground="White" 
                                         FontSize="28" 
                                         FontWeight="Black"/>
                            </StackPanel>
                            <TextBlock Text="BOUTIQUE // SYSTEM" 
                                     Foreground="{StaticResource CyberCyanBrush}" 
                                     FontSize="10" 
                                     FontWeight="Black" 
                                     Margin="16,4,0,0" 
                                     Opacity="0.8"/>
                        </StackPanel>
                    </Border>

                    <!-- User Section -->
                    <Border DockPanel.Dock="Top" Margin="24,0,24,24" Background="#1E293B" CornerRadius="8" Padding="16">
                        <DockPanel>
                            <Border Width="40" Height="40" Background="{StaticResource CyberCyanBrush}" CornerRadius="20" DockPanel.Dock="Left">
                                <TextBlock Text="G" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentUser.FullName}" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding CurrentUser.Role}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Navigation Items -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,0">
                            <Button Content="DASHBOARD" 
                                    Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                                    Visibility="{Binding CanAccessDashboard, Converter={x:Static conv:StaticConverters.BoolToVisibilityConverter}}"
                                    Style="{StaticResource NavButton}">
                                <Button.Tag>
                                    <MultiBinding Converter="{x:Static conv:StaticConverters.TypeMatchConverter}">
                                        <Binding Path="CurrentView" />
                                        <Binding Source="{x:Type vm:DashboardViewModel}" />
                                    </MultiBinding>
                                </Button.Tag>
                            </Button>
                            
                            <Button Content="POS TERMINAL" 
                                    Command="{Binding NavigateCommand}" CommandParameter="POS"
                                    Style="{StaticResource NavButton}">
                                <Button.Tag>
                                    <MultiBinding Converter="{x:Static conv:StaticConverters.TypeMatchConverter}">
                                        <Binding Path="CurrentView" />
                                        <Binding Source="{x:Type vm:POSViewModel}" />
                                    </MultiBinding>
                                </Button.Tag>
                            </Button>
                            
                            <Button Content="INVENTORY" 
                                    Command="{Binding NavigateCommand}" CommandParameter="Inventory"
                                    Visibility="{Binding CanManageInventory, Converter={x:Static conv:StaticConverters.BoolToVisibilityConverter}}"
                                    Style="{StaticResource NavButton}">
                                <Button.Tag>
                                    <MultiBinding Converter="{x:Static conv:StaticConverters.TypeMatchConverter}">
                                        <Binding Path="CurrentView" />
                                        <Binding Source="{x:Type vm:InventoryViewModel}" />
                                    </MultiBinding>
                                </Button.Tag>
                            </Button>
                            
                            <Button Content="REPORTS" 
                                    Command="{Binding NavigateCommand}" CommandParameter="Reports"
                                    Visibility="{Binding CanViewReports, Converter={x:Static conv:StaticConverters.BoolToVisibilityConverter}}"
                                    Style="{StaticResource NavButton}">
                                <Button.Tag>
                                    <MultiBinding Converter="{x:Static conv:StaticConverters.TypeMatchConverter}">
                                        <Binding Path="CurrentView" />
                                        <Binding Source="{x:Type vm:ReportsViewModel}" />
                                    </MultiBinding>
                                </Button.Tag>
                            </Button>
                            
                            <Button Content="USER MANAGEMENT" 
                                    Command="{Binding NavigateCommand}" CommandParameter="Users"
                                    Visibility="{Binding CanManageUsers, Converter={x:Static conv:StaticConverters.BoolToVisibilityConverter}}"
                                    Style="{StaticResource NavButton}">
                                <Button.Tag>
                                    <MultiBinding Converter="{x:Static conv:StaticConverters.TypeMatchConverter}">
                                        <Binding Path="CurrentView" />
                                        <Binding Source="{x:Type vm:UsersViewModel}" />
                                    </MultiBinding>
                                </Button.Tag>
                            </Button>
                            
                            <Button Content="EVENT MODE" 
                                    Command="{Binding NavigateCommand}" CommandParameter="Event"
                                    Style="{StaticResource NavButton}">
                                <Button.Tag>
                                    <MultiBinding Converter="{x:Static conv:StaticConverters.TypeMatchConverter}">
                                        <Binding Path="CurrentView" />
                                        <Binding Source="{x:Type vm:EventViewModel}" />
                                    </MultiBinding>
                                </Button.Tag>
                            </Button>
                            
                            <Separator Background="{StaticResource BorderBrush}" Margin="24,20" Opacity="0.1"/>
                            
                            <Button Content="LOGOUT" 
                                    Command="{Binding LogoutCommand}"
                                    Style="{StaticResource NavButton}"
                                    Foreground="#EF4444"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Main Content Area -->
            <Grid Background="Transparent">
                <ContentControl Content="{Binding CurrentView}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                            <local:DashboardView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:POSViewModel}">
                            <local:POSView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:InventoryViewModel}">
                            <local:InventoryView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                            <local:ReportsView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
                            <local:UsersView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:EventViewModel}">
                            <local:EventView />
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
