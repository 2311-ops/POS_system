<UserControl x:Class="FashionPOS.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="{StaticResource DarkBgBrush}">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <!-- Product Selection Area -->
        <Border Grid.Column="0" Margin="0,0,24,0">
            <DockPanel>
                <!-- Terminal Header & Search -->
                <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Padding="28" Margin="0,0,0,24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="TERMINAL // POS"
                                       Style="{StaticResource SectionTitle}" />
                            <Border Background="{StaticResource CyberCyanBrush}"
                                    CornerRadius="6"
                                    Padding="10,2"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="ONLINE"
                                           Foreground="Black"
                                           FontSize="10"
                                           FontWeight="Black" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="READY TO PROCESS TRANSACTIONS // SELECT PRODUCTS BELOW"
                                   Style="{StaticResource SectionSubtitle}"
                                   Foreground="{StaticResource CyberCyanBrush}"
                                   FontWeight="Bold"
                                   Margin="0,0,0,24" />

                        <TextBox x:Name="SearchBox"
                                 Height="44"
                                 Padding="14,10"
                                 Background="#0D1526"
                                 Foreground="White"
                                 BorderBrush="#00AAFF"
                                 BorderThickness="1"
                                 FontSize="14"
                                 CaretBrush="#00AAFF"
                                 KeyDown="SearchBox_KeyDown"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged, Delay=300}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="HintBrush" TileMode="None" Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Search by SKU / Name / Barcode"
                                                           Foreground="#3A5070"
                                                           FontSize="14"
                                                           Padding="14,10" />
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource HintBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </Border>                <!-- Product Grid -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Products}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="180" Margin="8"
                                        Background="#0D1526"
                                        BorderBrush="#1E3050"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="120"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Image / Color zone -->
                                        <Border Grid.Row="0"
                                                CornerRadius="12,12,0,0"
                                                Background="#111B2E"
                                                ClipToBounds="True">
                                            <Grid>
                                                <!-- Color + Size label -->
                                                <StackPanel VerticalAlignment="Center"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding Color}"
                                                               Foreground="#3A5070"
                                                               FontSize="12"
                                                               TextAlignment="Center"/>
                                                    <TextBlock Text="{Binding Size}"
                                                               Foreground="#3A5070"
                                                               FontSize="11"
                                                               TextAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Out of stock overlay -->
                                                <Border Background="#CC000000"
                                                        CornerRadius="12,12,0,0"
                                                        Visibility="{Binding IsOutOfStock, Converter={StaticResource BoolToVisibility}}">
                                                    <StackPanel VerticalAlignment="Center"
                                                                HorizontalAlignment="Center">
                                                        <TextBlock Text="OUT OF STOCK"
                                                                   Foreground="#E05050"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"
                                                                   TextAlignment="Center"/>
                                                        <TextBlock Text="Cannot be added"
                                                                   Foreground="#888"
                                                                   FontSize="10"
                                                                   TextAlignment="Center"
                                                                   Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Low stock badge -->
                                                <Border VerticalAlignment="Top"
                                                        HorizontalAlignment="Right"
                                                        Margin="0,8,8,0"
                                                        Background="#7A2020"
                                                        CornerRadius="4"
                                                        Padding="6,3"
                                                        Visibility="{Binding IsLowStock, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="{Binding StockQuantity, StringFormat={}⚠ {0} left}"
                                                               Foreground="#FFB0B0"
                                                               FontSize="10"
                                                               FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <!-- Product Name -->
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Name}"
                                                   Foreground="White"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="40"
                                                   Margin="12,10,12,2"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Category / SKU -->
                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding CategoryName}"
                                                   Foreground="#3A6090"
                                                   FontSize="11"
                                                   Margin="12,0,12,8"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Price + ADD button -->
                                        <Grid Grid.Row="3" Margin="12,0,12,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding SellingPrice, StringFormat=${}{0:N2}}"
                                                       Foreground="#00AAFF"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>

                                            <Button Grid.Column="1"
                                                    Width="52" Height="36"
                                                    Background="#00AAFF"
                                                    Foreground="White"
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Content="+"
                                                    ToolTip="Add to cart"
                                                    IsEnabled="{Binding IsOutOfStock, Converter={StaticResource InverseBool}}"
                                                    Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="btn"
                                                                            Background="{TemplateBinding Background}"
                                                                            CornerRadius="8"
                                                                            Width="{TemplateBinding Width}"
                                                                            Height="{TemplateBinding Height}">
                                                                        <TextBlock Text="+"
                                                                                   Foreground="White"
                                                                                   FontSize="20"
                                                                                   FontWeight="Bold"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="btn"
                                                                                    Property="Background"
                                                                                    Value="#0088CC"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsEnabled" Value="False">
                                                                            <Setter TargetName="btn"
                                                                                    Property="Background"
                                                                                    Value="#1E2535"/>
                                                                            <Setter TargetName="btn"
                                                                                    Property="Opacity"
                                                                                    Value="0.4"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Transaction Panel -->
        <Border Grid.Column="1" Style="{StaticResource Card}" Background="#111827" BorderThickness="1" Padding="0" BorderBrush="{StaticResource CyberBlueBrush}">
            <DockPanel>
                <!-- Cart Header -->
                <Border DockPanel.Dock="Top" Background="#1E293B" Padding="24" CornerRadius="14,14,0,0">
                    <StackPanel>
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="ACTIVE CART" Foreground="White" FontSize="18" FontWeight="Black" />
                                <Border Background="{StaticResource CyberCyanBrush}" CornerRadius="4" Padding="10,2" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding CartItemCount}" Foreground="Black" FontSize="12" FontWeight="Black" />
                                </Border>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" Content="RESET" Command="{Binding ClearCartCommand}"
                                    Style="{StaticResource GhostButton}" Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}" Padding="10,4" FontSize="11" FontWeight="Bold" />
                        </Grid>
                        
                        <Separator Background="{StaticResource BorderBrush}" Margin="0,20" Opacity="0.3"/>
                        
                        <TextBlock Text="TOTAL PAYABLE AMOUNT" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Black" />
                        <TextBlock Text="{Binding CartTotal, StringFormat={}{0:C}}"
                                   Foreground="{StaticResource CyberCyanBrush}"
                                   FontSize="42" FontWeight="Black" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Process Button Area -->
                <Border DockPanel.Dock="Bottom" Background="#1E293B" Padding="24" CornerRadius="0,0,14,14">
                    <StackPanel>
                        <TextBlock Text="PAYMENT GATEWAY" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Black" Margin="0,0,0,12" />
                        <ComboBox SelectedItem="{Binding PaymentMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource ModernComboBox}"
                                  Height="48" Margin="0,0,0,24">
                            <ComboBox.ItemsSource>
                                <x:Array Type="{x:Type sys:String}">
                                    <sys:String>Cash</sys:String>
                                    <sys:String>Card</sys:String>
                                    <sys:String>Transfer</sys:String>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>

                        <!-- Pulse Animation Button -->
                        <Button Content="PROCESS TRANSACTION"
                                Command="{Binding CompleteSaleCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Height="64" FontWeight="Black" FontSize="16"
                                IsEnabled="{Binding CartHasItems}">
                        </Button>
                    </StackPanel>
                </Border>                <!-- Cart Items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20">
                    <ItemsControl ItemsSource="{Binding Cart}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0D1526"
                                        BorderBrush="#1E3050"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,0,0,8"
                                        Padding="14,12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Row 0: Name + Remove button -->
                                        <Grid Grid.Row="0">
                                            <TextBlock Text="{Binding Product.Name}"
                                                       Foreground="White"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,28,0"/>
                                            <Button HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Width="22" Height="22"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="Transparent">
                                                            <TextBlock Text="✕"
                                                                       Foreground="#E05050"
                                                                       FontSize="14"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>

                                        <!-- Row 1: Price per unit -->
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Product.SellingPrice, StringFormat=${}{0:N2} each}"
                                                   Foreground="#00AAFF"
                                                   FontSize="12"
                                                   Margin="0,4,0,10"/>

                                        <!-- Row 2: Qty controls + Total -->
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Qty control group -->
                                            <Border Grid.Column="0"
                                                    Background="#111B2E"
                                                    BorderBrush="#1E3050"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <StackPanel Orientation="Horizontal">

                                                    <!-- MINUS button -->
                                                    <Button Width="34" Height="34"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Command="{Binding DataContext.DecrementQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="minusBtn"
                                                                        Background="Transparent"
                                                                        CornerRadius="7,0,0,7"
                                                                        Width="34" Height="34">
                                                                    <TextBlock Text="−"
                                                                               Foreground="White"
                                                                               FontSize="18"
                                                                               FontWeight="Bold"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,0,2"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="minusBtn"
                                                                                Property="Background"
                                                                                Value="#1E3050"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>

                                                    <!-- Quantity display -->
                                                    <Border Width="36" Height="34"
                                                            BorderBrush="#1E3050"
                                                            BorderThickness="1,0">
                                                        <TextBlock Text="{Binding Quantity}"
                                                                   Foreground="White"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <!-- PLUS button -->
                                                    <Button Width="34" Height="34"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Command="{Binding DataContext.IncrementQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="plusBtn"
                                                                        Background="Transparent"
                                                                        CornerRadius="0,7,7,0"
                                                                        Width="34" Height="34">
                                                                    <TextBlock Text="+"
                                                                               Foreground="White"
                                                                               FontSize="18"
                                                                               FontWeight="Bold"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,0,2"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="plusBtn"
                                                                                Property="Background"
                                                                                Value="#1E3050"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>

                                                </StackPanel>
                                            </Border>

                                            <!-- Line total -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding TotalPrice, StringFormat=${}{0:N2}}"
                                                       Foreground="#C9A84C"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
