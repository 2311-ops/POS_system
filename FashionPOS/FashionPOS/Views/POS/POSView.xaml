<UserControl x:Class="FashionPOS.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="{StaticResource DarkBgBrush}">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <!-- Product Selection Area -->
        <Border Grid.Column="0" Margin="0,0,24,0">
            <DockPanel>
                <!-- Terminal Header & Search -->
                <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Padding="28" Margin="0,0,0,24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="TERMINAL // POS"
                                       Style="{StaticResource SectionTitle}" />
                            <Border Background="{StaticResource CyberCyanBrush}"
                                    CornerRadius="6"
                                    Padding="10,2"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="ONLINE"
                                           Foreground="Black"
                                           FontSize="10"
                                           FontWeight="Black" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="READY TO PROCESS TRANSACTIONS // SELECT PRODUCTS BELOW"
                                   Style="{StaticResource SectionSubtitle}"
                                   Foreground="{StaticResource CyberCyanBrush}"
                                   FontWeight="Bold"
                                   Margin="0,0,0,24" />

                        <Grid>
                            <TextBox x:Name="SearchBox"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                     Style="{StaticResource ModernTextBox}" 
                                     Height="54"
                                     KeyDown="SearchBox_KeyDown"
                                     FontSize="16" />
                            <TextBlock Text="SEARCH QUANTUM DATABASE [SKU / NAME / BARCODE]" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       IsHitTestVisible="False"
                                       Margin="16,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Visibility="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Text, Converter={StaticResource InverseBoolToVisibility}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=SearchBox, Path=Text.Length}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Product Grid -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Products}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}" Margin="8" Padding="14" RenderTransformOrigin="0.5,0.5">
                                    <!-- Hover Zoom Animation -->
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                    </Border.RenderTransform>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal" />
                                            <VisualState x:Name="MouseOver">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.2" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.2" />
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Centered Image Container -->
                                        <Border Grid.Row="0" Height="160" Background="#111827" CornerRadius="10" Margin="0,0,0,16" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                                            <Grid>
                                                <Image Source="{Binding ImagePath}" Stretch="Uniform" Margin="10" />
                                                <TextBlock Text="NO IMAGE DATA" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                            Foreground="{StaticResource TextSecondaryBrush}" 
                                                           FontSize="9" FontWeight="Black" Opacity="0.5"
                                                           Visibility="{Binding ImagePath, Converter={StaticResource InverseBoolToVisibility}}"/>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Row="1" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="White" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding SKU}" FontSize="10" Foreground="{StaticResource CyberCyanBrush}" FontWeight="Bold" Margin="0,4,0,0" />
                                        </StackPanel>

                                        <DockPanel Grid.Row="2" Margin="0,16,0,0">
                                            <TextBlock Text="{Binding SellingPrice, StringFormat={}{0:C}}" 
                                                       VerticalAlignment="Center" FontWeight="Black" FontSize="18" Foreground="{StaticResource CyberCyanBrush}" />
                                            <Button Content="ADD" 
                                                    Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    HorizontalAlignment="Right"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Padding="16,8" Height="36" />
                                        </DockPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Transaction Panel -->
        <Border Grid.Column="1" Style="{StaticResource Card}" Background="#111827" BorderThickness="1" Padding="0" BorderBrush="{StaticResource CyberBlueBrush}">
            <DockPanel>
                <!-- Cart Header -->
                <Border DockPanel.Dock="Top" Background="#1E293B" Padding="24" CornerRadius="14,14,0,0">
                    <StackPanel>
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="ACTIVE CART" Foreground="White" FontSize="18" FontWeight="Black" />
                                <Border Background="{StaticResource CyberCyanBrush}" CornerRadius="4" Padding="10,2" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding CartItemCount}" Foreground="Black" FontSize="12" FontWeight="Black" />
                                </Border>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" Content="RESET" Command="{Binding ClearCartCommand}"
                                    Style="{StaticResource GhostButton}" Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}" Padding="10,4" FontSize="11" FontWeight="Bold" />
                        </Grid>
                        
                        <Separator Background="{StaticResource BorderBrush}" Margin="0,20" Opacity="0.3"/>
                        
                        <TextBlock Text="TOTAL PAYABLE AMOUNT" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Black" />
                        <TextBlock Text="{Binding CartTotal, StringFormat={}{0:C}}"
                                   Foreground="{StaticResource CyberCyanBrush}"
                                   FontSize="42" FontWeight="Black" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Process Button Area -->
                <Border DockPanel.Dock="Bottom" Background="#1E293B" Padding="24" CornerRadius="0,0,14,14">
                    <StackPanel>
                        <TextBlock Text="PAYMENT GATEWAY" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Black" Margin="0,0,0,12" />
                        <ComboBox SelectedItem="{Binding PaymentMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource ModernComboBox}"
                                  Height="48" Margin="0,0,0,24">
                            <ComboBox.ItemsSource>
                                <x:Array Type="{x:Type sys:String}">
                                    <sys:String>Cash</sys:String>
                                    <sys:String>Card</sys:String>
                                    <sys:String>Transfer</sys:String>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>

                        <!-- Pulse Animation Button -->
                        <Button Content="PROCESS TRANSACTION"
                                Command="{Binding CompleteSaleCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Height="64" FontWeight="Black" FontSize="16"
                                IsEnabled="{Binding CartHasItems}">
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Cart Items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20">
                    <ItemsControl ItemsSource="{Binding Cart}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E293B" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
    
                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="{Binding Product.Name}" Foreground="White" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Product.SellingPrice, StringFormat={}{0:C}}" Foreground="{StaticResource CyberCyanBrush}" FontSize="13" FontWeight="Bold" Margin="0,4,0,0" />
                                        </StackPanel>
    
                                        <Button Grid.Row="0" Grid.Column="1" Content="&#x2715;" 
                                                Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource GhostButton}" BorderThickness="0" Foreground="{StaticResource DangerBrush}" FontSize="14" VerticalAlignment="Top" Padding="4,0" />
    
                                        <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,16,0,0" Background="#111827" CornerRadius="8" Padding="12,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
    
                                                <TextBlock Text="{Binding Quantity, StringFormat=QTY: {0}}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="Black" VerticalAlignment="Center" />
    
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Content="-" Width="28" Height="28" Command="{Binding DataContext.DecrementQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource GhostButton}" Foreground="White" />
                                                    <TextBlock Text="{Binding Quantity}" Width="36" TextAlignment="Center" Foreground="White" FontWeight="Black" FontSize="14" VerticalAlignment="Center" />
                                                    <Button Content="+" Width="28" Height="28" Command="{Binding DataContext.IncrementQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource GhostButton}" Foreground="White" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
