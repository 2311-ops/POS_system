<UserControl x:Class="FashionPOS.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource DarkBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <!-- Header Section -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="FINANCIAL INTELLIGENCE" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="RECURSIVE SALES AUDIT // PROFIT ANALYSIS // GLOBAL EXPORT"
                                   Style="{StaticResource SectionSubtitle}"
                                   Foreground="{StaticResource CyberCyanBrush}"
                                   FontWeight="Bold"
                                   Opacity="0.8"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Style="{StaticResource Badge}" Margin="0,0,16,0" BorderBrush="{StaticResource CyberCyanBrush}">
                            <TextBlock Text="{Binding TotalTransactions, StringFormat={}{0} TRANSACTIONS}"
                                       Foreground="{StaticResource CyberCyanBrush}"
                                       FontSize="10"
                                       FontWeight="Black" />
                        </Border>
                        <Button Content="EXPORT MASTER"
                                Command="{Binding ExportExcelCommand}"
                                Style="{StaticResource PrimaryButton}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Filters & Snapshot -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="TEMPORAL FILTERS" Style="{StaticResource SectionTitle}" FontSize="18" />
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="FROM DATE" Style="{StaticResource InputLabel}" />
                                <DatePicker SelectedDate="{Binding FromDate, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="TO DATE" Style="{StaticResource InputLabel}" />
                                <DatePicker SelectedDate="{Binding ToDate, Mode=TwoWay}" />
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Content="QUERY SYSTEM"
                                    Command="{Binding LoadReportCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    VerticalAlignment="Bottom"
                                    Height="42" />
                        </Grid>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource SectionSubtitle}"
                                   Foreground="{StaticResource CyberCyanBrush}"
                                   Margin="0,12,0,0"
                                   FontWeight="Bold"
                                   Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="SNAPSHOT" Style="{StaticResource SectionTitle}" FontSize="18" />
                        <StackPanel Margin="0,16,0,0">
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="REVENUE" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" FontSize="11"/>
                                <TextBlock Text="{Binding TotalRevenue, StringFormat=C}" HorizontalAlignment="Right" Foreground="White" FontWeight="Black" FontSize="16"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="PROFIT" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" FontSize="11"/>
                                <TextBlock Text="{Binding TotalProfit, StringFormat=C}" HorizontalAlignment="Right" Foreground="{StaticResource SuccessBrush}" FontWeight="Black" FontSize="16"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="AVG VALUE" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" FontSize="11"/>
                                <TextBlock Text="PRECISE" HorizontalAlignment="Right" Foreground="{StaticResource CyberBlueBrush}" FontWeight="Black" FontSize="16"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Sales list -->
            <Border Style="{StaticResource Card}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="TRANSACTION LOG"
                               Style="{StaticResource SectionTitle}"
                               FontSize="18"
                               Margin="0,0,0,16" />

                    <DataGrid ItemsSource="{Binding Sales}"
                              Style="{StaticResource ModernDataGrid}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SALE ID" Binding="{Binding SaleNumber}" Width="*" />
                            <DataGridTextColumn Header="CASHIER" Binding="{Binding CashierName}" Width="*" />
                            <DataGridTextColumn Header="PAYMENT" Binding="{Binding PaymentMethod}" Width="120" />
                            <DataGridTextColumn Header="TOTAL" Binding="{Binding TotalAmount, StringFormat=C}" Width="120" />
                            <DataGridTextColumn Header="TIMESTAMP" Binding="{Binding CreatedAt, StringFormat={}{0:MMM dd, HH:mm}}" Width="160" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
